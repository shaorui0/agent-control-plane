<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="refresh" content="{{ data.refresh_seconds }}">
  <title>ACP Dashboard</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; margin: 24px; color: #1a1a1a; }
    h1 { font-size: 22px; margin-bottom: 4px; }
    h2 { font-size: 16px; margin-top: 32px; border-bottom: 1px solid #ddd; padding-bottom: 4px; }
    table { border-collapse: collapse; width: 100%; margin-top: 8px; font-size: 13px; }
    th, td { text-align: left; padding: 6px 10px; border-bottom: 1px solid #eee; }
    th { background: #fafafa; font-weight: 600; }
    .pill { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 12px; font-weight: 600; }
    .tier { background: #e8edff; color: #1d2eaa; }
    .green { background: #d8f5d8; color: #0a5a0a; }
    .yellow { background: #fff5cc; color: #6a4a00; }
    .orange { background: #ffe0c2; color: #7a3a00; }
    .red { background: #ffd0d0; color: #800; }
    .count { font-weight: 600; }
    .muted { color: #666; }
    a { color: #1d4eaa; text-decoration: none; }
    a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <h1>ACP Dashboard</h1>
  <div class="muted">Auto-refresh every {{ data.refresh_seconds }}s.</div>

  <h2>Agents</h2>
  {% if data.agents %}
  <table>
    <tr><th>agent_id</th><th>owner</th><th>model</th><th>default</th><th>tiers</th><th>snapshots</th></tr>
    {% for a in data.agents %}
    <tr>
      <td><strong>{{ a.agent_id }}</strong></td>
      <td>{{ a.owner }}</td>
      <td>{{ a.model_version }}</td>
      <td><span class="pill tier">{{ a.default_tier }}</span></td>
      <td>
        {% for t in a.tiers %}
          <span class="pill tier">{{ t.task_class }}={{ t.tier }}</span>
        {% endfor %}
      </td>
      <td>
        {% for s in a.snapshots %}
          <span class="pill {{ s.color }}" title="window={{ s.window_label }} class={{ s.budget_class }} burn={{ '%.2f'|format(s.burn_rate) }} remaining={{ '%.2f'|format(s.budget_remaining) }}">
            {{ s.task_class }}/{{ s.window_label }}: {{ '%.1f'|format(s.burn_rate) }}x
          </span>
        {% else %}
          <span class="muted">no snapshots yet</span>
        {% endfor %}
      </td>
    </tr>
    {% endfor %}
  </table>
  {% else %}
  <div class="muted">No agents registered.</div>
  {% endif %}

  <h2>Queues</h2>
  <div>
    Approvals pending: <span class="count">{{ data.pending_approvals }}</span>
    &mdash; <a href="/approvals">view</a>
  </div>
  <div>
    Audits pending: <span class="count">{{ data.pending_audits }}</span>
    &mdash; <a href="/audit">view</a>
  </div>

  <h2>Recent events (last 20)</h2>
  {% if data.recent_events %}
  <table>
    <tr><th>ts</th><th>agent</th><th>type</th><th>tool</th><th>outcome</th><th>run</th></tr>
    {% for e in data.recent_events %}
    <tr>
      <td>{{ e.ts }}</td>
      <td>{{ e.agent_id }}</td>
      <td>{{ e.event_type }}</td>
      <td>{{ e.tool_name }}</td>
      <td>{{ e.outcome }}</td>
      <td><a href="/v1/trace/{{ e.run_id }}">{{ e.run_id[:12] }}…</a></td>
    </tr>
    {% endfor %}
  </table>
  {% else %}
  <div class="muted">No events yet.</div>
  {% endif %}
</body>
</html>
